# ============================================
# Environment Variables Template
# Usage:
# 1. Copy this file and rename it to .env
#    cp .env.example .env
# 2. Modify the values below
# ============================================

# Application Settings
ENVIRONMENT=development
DEBUG=True

# Database Settings (Compatible with docker-compose.yml)
DB_HOST=postgres
DB_PORT=5433
DB_USER=notes_user
DB_PASSWORD=notes_pass  # Use simple password for development
DB_NAME=notes_db

# Complete Database URL (Optionally use this or the individual settings above)
DATABASE_URL=postgresql://notes_user:notes_pass@postgres:5432/notes_db

# CORS Settings (Allow all origins during development)
CORS_ORIGINS=*

# ============================================
# Notes:
# - DB_HOST=postgres corresponds to the service name in docker-compose
# - Use simple passwords for local development; use strong passwords for production
# - CORS_ORIGINS=* is for development only; set to specific domains in production
# ============================================